        { text: "既能与盐酸反应又能与NaOH溶液反应的物质是", options: ["Na₂CO₃", "Fe₂O₃", "CO₂", "Al(OH)₃"], correct: "D" },
        { text: "下列实验操作正确的是", options: ["稀释浓硫酸时将水倒入浓硫酸中", "点燃氢气前必须验纯", "用酒精灯直接加热烧杯", "将鼻孔凑到瓶口闻氯气气味"], correct: "B" },
        { text: "下列物质中，含有非极性共价键的是", options: ["H₂O", "CO₂", "H₂O₂", "NaOH"], correct: "C" },
