        { text: "关于NO₂描述错误的是", options: ["红棕色气体", "能与水反应", "属于酸性氧化物", "会引起光化学烟雾"], correct: "C" },
        { text: "1 mol CH₄中含有共价键的数目是", options: ["4N_A", "1N_A", "2N_A", "5N_A"], correct: "A" },
        { text: "常温下，铁制容器可用于盛放", options: ["浓硫酸", "稀硫酸", "浓盐酸", "硫酸铜溶液"], correct: "A" },
        { text: "下列物质中酸性最强的是", options: ["H₂SiO₃", "H₃PO₄", "H₂SO₄", "HClO₄"], correct: "D" },
