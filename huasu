        { text: "1 mol CH₄完全燃烧生成CO₂和H₂O，转移电子数为 ______ N<sub>A</sub>。", answer: "8" },
        { text: "工业上合成氨的反应条件是高温高压和 ______。", answer: "催化剂(铁触媒)" },
        { text: "铝合金常用于制造门窗，主要利用其密度小和 ______ 性好。", answer: "抗腐蚀" },
        { text: "将一小块钠投入硫酸铜溶液中，现象有产生气体和 ______ 沉淀。", answer: "蓝色" },
        { text: "氢氟酸不能存放在玻璃瓶中，因为会腐蚀玻璃，反应方程式为：______。", answer: "SiO₂ + 4HF = SiF₄↑ + 2H₂O" },
        { text: "写出实验室制取氨气的化学方程式：______。", answer: "2NH₄Cl + Ca(OH)₂ = CaCl₂ + 2NH₃↑ + 2H₂O" },
        { text: "在硝酸酸化的BaCl₂溶液中，加入某溶液产生白色沉淀，该溶液中可能含 ______ 离子。", answer: "SO₄²⁻ 或 Ag⁺" },
        { text: "相同质量的水和乙醇，含氢原子数较多的是 ______。", answer: "水" },
        { text: "生活中常用小苏打治疗胃酸过多，离子方程式为 ______。", answer: "HCO₃⁻ + H⁺ = CO₂↑ + H₂O" },
        { text: "能与铝粉反应产生氢气的溶液可能呈 ______ 性或碱性。", answer: "酸" },
        { text: "在元素周期表中，金属性和非金属性分界线附近的元素常用于制造 ______ 材料。", answer: "半导体" },
        { text: "除去Na₂CO₃固体中混有的少量NaHCO₃，可采用 ______ 方法。", answer: "加热" },
        { text: "HClO的酸性比H₂CO₃ ______ (填“强”或“弱”)。", answer: "弱" },
        { text: "海水提溴过程中，向浓缩的海水中通入氯气，发生反应的离子方程式：______。", answer: "Cl₂ + 2Br⁻ = Br₂ + 2Cl⁻" },
        { text: "葡萄糖的分子式是 ______。", answer: "C₆H₁₂O₆" },
        { text: "油脂在碱性条件下的水解反应称为 ______ 反应。", answer: "皂化" },
        { text: "蛋白质遇浓硝酸发生 ______ 反应（填颜色）。", answer: "黄" },
        { text: "通常用来衡量一个国家石油化工发展水平的物质是 ______。", answer: "乙烯" },
        { text: "硝酸保存在棕色试剂瓶中，原因是 ______。", answer: "见光分解" },
        { text: "（图示题）过滤操作中，玻璃棒的作用是 ______。", answer: "引流" },
        { text: "（附加）容量瓶上标有温度、刻度线和 ______。", answer: "容积" },
        { text: "在2A+B⇌3C中，增加压强，平衡向 ______ 方向移动（已知A、B、C均为气体）。", answer: "正反应" },
        { text: "常温下，铝制容器可盛装浓硫酸，因为铝表面 ______。", answer: "钝化" },
        { text: "在化学反应中，升高温度会 ______ 反应速率。", answer: "加快" }
    ];
    // 确保填空题55题
    console.assert(fillBank.length === 55, "填空题数量须55");

    // 动态渲染选择题
    function renderChoices() {
        const container = document.getElementById('choiceContainer');
        let html = `<div class="section-title">一、选择题（共45题，每题1分，共45分）</div><div class="question-grid">`;
        choiceBank.forEach((item, idx) => {
            html += `<div class="choice-item" data-qidx="${idx}">
                        <div class="question-text"><span class="question-num">${idx+1}.</span> ${item.text}</div>
                        <div class="options">`;
            const opts = ['A', 'B', 'C', 'D'];
            item.options.forEach((opt, optIdx) => {
                html += `<label class="option"><input type="radio" name="q_${idx}" value="${opts[optIdx]}"> ${opts[optIdx]}. ${opt}</label>`;
            });
            html += `</div><div class="feedback" id="fb_${idx}"></div></div>`;
        });
        html += `</div>`;
        container.innerHTML = html;
    }

    // 填空题渲染（每个填空题独立，题目编号46~100）
    function renderFills() {
        const container = document.getElementById('fillContainer');
        let html = `<div class="section-title">二、填空题（共55题，每题1分，共55分）</div><div class="question-grid">`;
        fillBank.forEach((item, idx) => {
            const realNum = 46 + idx;
            // 特殊: 第51题(索引5) 插入过滤图示
            let diagramHtml = '';
            if (realNum === 51) {
                diagramHtml = `<div class="chem-diagram">
                    <svg width="180" height="130" viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="65,30 135,30 115,80 85,80" fill="#d9eaf5" stroke="#2c7da0" stroke-width="2"/>
                        <line x1="100" y1="80" x2="100" y2="100" stroke="#5c8f9c" stroke-width="2"/>
                        <rect x="45" y="95" width="110" height="28" rx="6" fill="#eef2f5" stroke="#2c7da0" stroke-width="1.5"/>
                        <text x="78" y="65" font-size="8" fill="#1e466e">漏斗</text>
                        <text x="135" y="110" font-size="8" fill="#1e466e">烧杯</text>
                        <line x1="92" y1="28" x2="78" y2="72" stroke="#867f6e" stroke-width="2.5" stroke-dasharray="3 2"/>
                        <text x="62" y="45" font-size="7" fill="#5a4e3c">玻璃棒</text>
                    </svg>
                    <span style="font-size:0.7rem;">🔍 过滤操作装置图</span>
                </div>`;
            }
            html += `<div class="fill-item" data-fillidx="${idx}">
                        <div class="question-text"><span class="question-num">${realNum}.</span> ${item.text}</div>
                        ${diagramHtml}
                        <div class="fill-input"><input type="text" id="fill_${idx}" placeholder="填写答案" style="width:320px;"></div>
                        <div class="answer-hint" id="hint_fill_${idx}"></div>
                    </div>`;
        });
        html += `</div>`;
        container.innerHTML = html;
    }

    // 批改选择题
    function markChoices() {
        let score = 0;
        for (let i = 0; i < choiceBank.length; i++) {
            const selectedRadio = document.querySelector(`input[name="q_${i}"]:checked`);
            const feedbackDiv = document.getElementById(`fb_${i}`);
            const correctAns = choiceBank[i].correct;
            if (selectedRadio) {
                const userVal = selectedRadio.value;
                if (userVal === correctAns) {
                    score++;
                    feedbackDiv.innerHTML = `<span class="correct-badge">✓ 正确</span>`;
                } else {
                    feedbackDiv.innerHTML = `<span class="wrong-badge">✗ 错误，正确答案是 ${correctAns}</span>`;
                }
            } else {
                feedbackDiv.innerHTML = `<span class="wrong-badge">未作答 (正确答案 ${correctAns})</span>`;
            }
        }
        const scoreDiv = document.getElementById("choiceScoreDisplay");
        scoreDiv.style.display = "block";
        scoreDiv.innerHTML = `📊 选择题得分：${score} / 45分 (每题1分) ${score>=36?'🌟 优秀':(score>=27?'📘 良好':'📚 加油')}`;
    }

    function resetChoices() {
        for (let i = 0; i < choiceBank.length; i++) {
            const radios = document.querySelectorAll(`input[name="q_${i}"]`);
            radios.forEach(radio => radio.checked = false);
            const fb = document.getElementById(`fb_${i}`);
            if (fb) fb.innerHTML = "";
        }
        document.getElementById("choiceScoreDisplay").style.display = "none";
    }

    // 显示所有填空题的参考答案
    function showFillAnswers() {
        for (let i = 0; i < fillBank.length; i++) {
            const hintDiv = document.getElementById(`hint_fill_${i}`);
            if (hintDiv) {
                hintDiv.innerHTML = `📌 参考答案：${fillBank[i].answer}`;
                hintDiv.classList.add("show");
            }
        }
    }
    function hideFillAnswers() {
        for (let i = 0; i < fillBank.length; i++) {
            const hintDiv = document.getElementById(`hint_fill_${i}`);
            if (hintDiv) {
                hintDiv.classList.remove("show");
                hintDiv.innerHTML = "";
            }
        }
    }

    // 页面初始化
    window.addEventListener("DOMContentLoaded", () => {
        renderChoices();
        renderFills();
        document.getElementById("markChoiceBtn").addEventListener("click", markChoices);
        document.getElementById("resetChoiceBtn").addEventListener("click", resetChoices);
        document.getElementById("showFillAnswersBtn").addEventListener("click", showFillAnswers);
        document.getElementById("hideFillAnswersBtn").addEventListener("click", hideFillAnswers);
    });
</script>
</body>
</html>
